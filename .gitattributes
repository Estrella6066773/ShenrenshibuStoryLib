# Unity 合并与行尾（需安装 UnityYAMLMerge 或 Smart Merge）
* text=auto

*.cs     diff=csharp text
*.cginc  text
*.shader text

*.md     text eol=crlf
*.yaml   text eol=crlf
*.yml    text eol=crlf

*.mat    merge=unityyamlmerge eol=lf
*.anim   merge=unityyamlmerge eol=lf
*.unity  merge=unityyamlmerge eol=lf
*.prefab merge=unityyamlmerge eol=lf
*.asset  merge=unityyamlmerge eol=lf
*.meta   merge=unityyamlmerge eol=lf
*.controller merge=unityyamlmerge eol=lf

# 二进制资源
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.psd  binary
*.tga  binary
*.tif  binary
*.tiff binary
*.exr  binary
*.hdr  binary
*.wav  binary
*.mp3  binary
*.ogg  binary
*.fbx  binary
*.blend binary
*.dll  binary
*.so   binary
*.dylib binary
*.a    binary
*.bundle binary
