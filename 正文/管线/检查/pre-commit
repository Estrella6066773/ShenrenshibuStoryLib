#!/bin/sh
# 提交前：尝试自动修正 正文/ 内链接 → 复检 → 将修正纳入暂存区
# 安装：git config core.hooksPath 正文/管线/检查

set -e

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$ROOT" ]; then
  ROOT="$(cd "$(dirname "$0")/../../.." && pwd)"
fi

cd "$ROOT" || exit 1
exec python "正文/管线/检查/check-links.py" --fix --stage-fixed
